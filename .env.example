# Required: Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Comma-separated origins for CORS (frontend URLs)
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000

# Django
DEBUG=True
SECRET_KEY=your-django-secret-key

# Production (Cloud Run + Cloud SQL): Unix socket URL, password URL-encoded if needed
# DATABASE_URL=postgres://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# Optional: OpenAI model (default: gpt-3.5-turbo)
# OPENAI_MODEL=gpt-4

# Optional: Custom system prompt
# OPENAI_SYSTEM_PROMPT=You are a helpful assistant.

# Intake + Twilio Voice (production: set on Cloud Run or via CI secrets)
# PUBLIC_BASE_URL=https://your-service-xxxxx.run.app
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# OPENAI_MODEL=gpt-4o-mini

# Leads dashboard API (GET /api/leads/). In production (DEBUG=False) this key is required.
# Frontend: set VITE_LEADS_API_KEY to the same value and send X-API-Key from the app.
# LEADS_API_KEY=your-long-random-secret
